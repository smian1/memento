# Memento - Environment Configuration
#
# Copy this file to .env and add your actual values
# NEVER commit your .env file to version control

# Your Limitless AI API Key
# Get this from: https://www.limitless.ai/developers
# Example: LIMITLESS_API_KEY=your-actual-api-key-here
LIMITLESS_API_KEY=your_limitless_api_key_here

# Optional: Configure sync timing (defaults to 7:00 AM Pacific)
# DAILY_INSIGHT_HOUR=7

# Optional: Database file location (defaults to backend/insights.db)
# DATABASE_PATH=backend/insights.db
